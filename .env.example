# Neon Postgres — pooled (PgBouncer, transaction mode) connection string.
# Used for all request-time queries from serverless functions.
DATABASE_URL=

# Neon Postgres — direct (unpooled) connection string.
# Used only for migrations, which need session-level guarantees.
DATABASE_URL_UNPOOLED=

# JWT signing secret for Authorization: Bearer tokens issued by POST /auth/apple
# and POST /auth/device. Generate with: openssl rand -base64 32
JWT_SIGNING_SECRET=

# Sign in with Apple — used to verify identity_token in POST /auth/apple.
# Get these from https://developer.apple.com/account/resources/identifiers
APPLE_CLIENT_ID=
APPLE_TEAM_ID=

# APNs (Apple Push Notification service) — HTTP/2 push from Node.js serverless
# functions. Get these from https://developer.apple.com/account/resources/authkeys
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_PRIVATE_KEY=
APNS_BUNDLE_ID=
APNS_ENVIRONMENT=sandbox

# Shared secret required in the Authorization header of Vercel Cron requests,
# so /api/internal/cron/* routes can't be triggered by anyone else.
# Generate with: openssl rand -base64 32
CRON_SECRET=
